# =============================================================================
# Mutual Fund FAQ Assistant - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
# =============================================================================

# Required ---------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here

# Optional (defaults shown) -----------------------------------------------

# LLM Model
GEMINI_MODEL=gemini-2.0-flash

# Embedding model: "gemini" (API) or "local" (sentence-transformers)
EMBEDDING_MODEL=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSION=768

# Qdrant connection (use QDRANT_URL for Qdrant Cloud, e.g. https://xxx.cloud.qdrant.io)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=mutual_fund_faq

# Retrieval parameters
RETRIEVAL_TOP_K=5
RETRIEVAL_THRESHOLD=0.65
RERANK_TOP_N=3
MMR_LAMBDA=0.7

# Response constraints
MAX_RESPONSE_SENTENCES=3
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.95
LLM_MAX_OUTPUT_TOKENS=256

# Rate limiting (requests per minute per IP)
RATE_LIMIT=10/minute

# Scheduler — local APScheduler service (phase-1-data-collection/scheduler_service.py)
SCHEDULER_ENABLED=true
SCHEDULER_CRON_HOUR=9
SCHEDULER_CRON_MINUTE=15
SCHEDULER_TIMEZONE=Asia/Kolkata

# Scraping (phase-1)
SCRAPE_DELAY_SECONDS=2
SCRAPE_MAX_PDFS_PER_PAGE=30
SCRAPE_REQUEST_TIMEOUT=60

# Embedding batch size (phase-2 ingest)
EMBEDDING_BATCH_SIZE=64

# Logging
LOG_LEVEL=INFO
